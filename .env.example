# Conexión a Postgres (Vercel Postgres / Neon).
DATABASE_URL="postgresql://usuario:password@host/carta?sslmode=require"

# Secreto para firmar las sesiones JWT de NextAuth.
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-este-valor"

# URL pública de la app. En local: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
